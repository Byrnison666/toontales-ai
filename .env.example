# === Продакшн (docker-compose.prod.yml) ===
# Домен сайта (без протокола) и email для Let's Encrypt — Caddy авто-HTTPS.
SITE_DOMAIN=toontales.ru
ACME_EMAIL=i@byrnison.ru
# Пароль БД в проде (openssl rand -hex 32). В prod-compose подставляется в
# POSTGRES_PASSWORD и в TOONTALES_DATABASE_URL. Для dev можно оставить как есть.
POSTGRES_PASSWORD=toontales

TOONTALES_DATABASE_URL=postgresql+asyncpg://toontales:toontales@postgres:5432/toontales
TOONTALES_TEST_DATABASE_URL=postgresql+psycopg://toontales:toontales@postgres:5432/toontales_test
TOONTALES_REDIS_URL=redis://redis:6379/0

TOONTALES_S3_ENDPOINT_URL=https://s3.example.com
TOONTALES_S3_BUCKET=toontales-media
TOONTALES_S3_REGION=us-east-1
TOONTALES_S3_ACCESS_KEY=replace-me
TOONTALES_S3_SECRET_KEY=replace-me

TOONTALES_EPHEMERAL_ASSET_TTL_DAYS=14
TOONTALES_WS_TICKET_TTL_SECONDS=60

# Порт, на котором worker/beat поднимают отдельный HTTP-сервер для Prometheus
# scrape (их метрики физически не видны на /metrics FastAPI-процесса).
TOONTALES_METRICS_PORT=9100

# Сгенерируйте значение командой: openssl rand -hex 32
TOONTALES_JWT_SECRET=replace-with-at-least-32-random-bytes
TOONTALES_JWT_ALGORITHM=HS256
TOONTALES_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440

# Секрет для admin-эндпоинтов (пополнение баланса и т.п.), заголовок X-Admin-Key.
# Сгенерируйте: openssl rand -hex 32. Пустое значение блокирует admin-эндпоинты.
TOONTALES_ADMIN_API_KEY=replace-with-random-admin-secret

# Стартовый бонус кредитов новому юзеру при регистрации.
# 0 (по умолчанию) = без бонуса, пополнение только админом (X-Admin-Key). Любой
# ненулевой бонус раздаёт реальные деньги (~$3.58/ролик) и абузится мультиаккаунтами
# (temp-mail/VPN обходят email-verify и IP-лимиты). Включать только вместе с картой
# на файле (Stripe SetupIntent). До этого ценность демонстрируется роликом на лендинге.
TOONTALES_SIGNUP_BONUS_CREDITS=0

TOONTALES_MODERATION_FAIL_OPEN=false
TOONTALES_RATE_LIMIT_GENERATE_PER_MINUTE=5
# Макс. одновременно незавершённых роликов на юзера (anti-abuse: баланс не
# резервируется на старте, лимит не даёт жечь ресурсы провайдеров параллельно).
# =1: пока текущий ролик не дошёл до точки списания, новый не запустить.
TOONTALES_MAX_ACTIVE_RUNS_PER_USER=1

TOONTALES_ELEVENLABS_API_KEY=replace-me
TOONTALES_ELEVENLABS_VOICE_ID=replace-me
TOONTALES_ELEVENLABS_MODEL_ID=eleven_multilingual_v2

TOONTALES_RUNWAY_API_KEY=replace-me
# Модель image-to-video. gen4_turbo ($0.05/с) вдвое дешевле gen4.5 ($0.10/с) —
# дефолт для экономии. При смене на gen4.5 обновить RUNWAY_VIDEO_CREDITS_PER_SECOND
# в real_cost.py (10 вместо 5).
TOONTALES_RUNWAY_VIDEO_MODEL=gen4_turbo

TOONTALES_SYNC_API_KEY=replace-me
TOONTALES_SYNC_MODEL=lipsync-2
# Лимит одновременных генераций Sync.so (тариф hobbyist=1). При апгрейде — поднять.
TOONTALES_SYNC_MAX_CONCURRENCY=1

TOONTALES_ANTHROPIC_API_KEY=replace-me
TOONTALES_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Anthropic гео-блокирует РФ. На российском VPS укажите прокси вне РФ, иначе
# storyboard падает с 403. Формат: http://user:pass@host:port или socks5://host:port
# (socks требует httpx[socks]). Пусто = прямое соединение.
TOONTALES_ANTHROPIC_PROXY_URL=
