TOONTALES_DATABASE_URL=postgresql+asyncpg://toontales:toontales@postgres:5432/toontales
TOONTALES_TEST_DATABASE_URL=postgresql+psycopg://toontales:toontales@postgres:5432/toontales_test
TOONTALES_REDIS_URL=redis://redis:6379/0

TOONTALES_S3_ENDPOINT_URL=https://s3.example.com
TOONTALES_S3_BUCKET=toontales-media
TOONTALES_S3_REGION=us-east-1
TOONTALES_S3_ACCESS_KEY=replace-me
TOONTALES_S3_SECRET_KEY=replace-me

TOONTALES_EPHEMERAL_ASSET_TTL_DAYS=14
TOONTALES_WS_TICKET_TTL_SECONDS=60

# Порт, на котором worker/beat поднимают отдельный HTTP-сервер для Prometheus
# scrape (их метрики физически не видны на /metrics FastAPI-процесса).
TOONTALES_METRICS_PORT=9100

# Сгенерируйте значение командой: openssl rand -hex 32
TOONTALES_JWT_SECRET=replace-with-at-least-32-random-bytes
TOONTALES_JWT_ALGORITHM=HS256
TOONTALES_JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440

TOONTALES_MODERATION_FAIL_OPEN=false
TOONTALES_RATE_LIMIT_GENERATE_PER_MINUTE=5

TOONTALES_ELEVENLABS_API_KEY=replace-me
TOONTALES_ELEVENLABS_VOICE_ID=replace-me
TOONTALES_ELEVENLABS_MODEL_ID=eleven_multilingual_v2

TOONTALES_RUNWAY_API_KEY=replace-me

TOONTALES_SYNC_API_KEY=replace-me
TOONTALES_SYNC_MODEL=lipsync-2
# Лимит одновременных генераций Sync.so (тариф hobbyist=1). При апгрейде — поднять.
TOONTALES_SYNC_MAX_CONCURRENCY=1

TOONTALES_ANTHROPIC_API_KEY=replace-me
TOONTALES_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
